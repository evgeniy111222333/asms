# Required environment variables for ACMS
# Copy to .env and fill in values

# JWT authentication - MUST be changed in production (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here

# PostgreSQL password
POSTGRES_PASSWORD=your-secure-postgres-password-here

# Encryption key for credential encryption (min 32 chars)
ENCRYPTION_KEY=your-32-char-minimum-encryption-key

# Optional
GRAFANA_PASSWORD=admin
